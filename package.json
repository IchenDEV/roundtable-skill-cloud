{
  "name": "roundtable-skill-cloud",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build:skills": "node scripts/build-skills-manifest.mjs",
    "predev": "pnpm run build:skills",
    "prebuild": "pnpm run build:skills",
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm run format:check && pnpm run lint",
    "check:all": "pnpm run format:check && pnpm run lint && pnpm run test:coverage",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:prod:yes": "vercel deploy --prod --yes",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,css,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@base-ui/react": "^1.3.0",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.3",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "deepagents": "^1.9.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "langchain": "^1.3.1",
    "lucide-react": "^1.7.0",
    "next": "15.5.14",
    "openai": "^6.33.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "3",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^50.39.0",
    "vitest": "3"
  }
}
