# Supabase（生产必填；本地可仅用 DEV_LLM_API_KEY 调试编排）
# 控制台 Authentication → URL：Redirect URLs 须包含
#   http://localhost:3000/auth/callback
#   以及生产 https://你的域名/auth/callback
# 否则邮件里的 redirect_to 会只剩 Site URL 根路径，易导致登录失败或 otp 表现异常。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 可选：分享链接中的绝对站址（未设时从请求头推断）
#NEXT_PUBLIC_SITE_URL=https://你的域名

# 加密用户 BYOK 密文（32+ 字符推荐）
KEY_ENCRYPTION_SECRET=

# 仅开发：绕过 Supabase BYOK（勿提交真实 Key）
DEV_LLM_API_KEY=
# 开发旁路时的笔会：openai | openrouter | anthropic | minimax | kimi | doubao
#DEV_LLM_PROVIDER=openai
# 开发旁路时覆盖接口根地址（OpenAI 兼容类；Anthropic 不用）
#DEV_LLM_BASE_URL=

# 默认模型（未在砚台填写时使用；Anthropic 可单独设）
DEFAULT_OPENAI_MODEL=gpt-4o-mini
#DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 可选：LangSmith（默认不用）
# LANGCHAIN_API_KEY=
